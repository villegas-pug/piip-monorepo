{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "share": "disabled",
  "subagent_depth": 1,
  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/orchestration.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "database/ddl/init/oracle-wallet.zip": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": {
      "apps/backend/**": "allow",
      "apps/frontend/**": "allow",
      "database/**": "allow",
      "*": "ask"
    },
    "bash": "ask",
    "task": "ask",
    "skill": "ask",
    "external_directory": "deny",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "lsp": "ask",
    "doom_loop": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "skill": "deny",
        "task": {
          "*": "deny",
          "explore": "allow",
          "frontend-specialist": "allow",
          "backend-specialist": "allow",
          "database-specialist": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "skill": "deny",
        "task": {
          "*": "deny",
          "explore": "allow",
          "frontend-specialist": "allow",
          "backend-specialist": "allow",
          "database-specialist": "allow"
        }
      }
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "skill": "deny"
      }
    }
  }
}
